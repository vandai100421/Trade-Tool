# ============================================
# CHỈ CẦN FILE NÀY CHO EMAIL THÔI
# ============================================

# Resend API key (BẮT BUỘC nếu muốn gửi email khi tín hiệu ĐẸP)
# 1. Vào https://resend.com → đăng ký miễn phí
# 2. API Keys → Create API Key → copy
# 3. Dán vào bên dưới:
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ============================================
# 2 GIÁ TRỊ DƯỚI ĐÂY KHÔNG CẦN ĐIỀN Ở ĐÂY
# → Nhập qua trang Settings của app (lưu trong browser)
# ============================================

# Twelve Data API key → nhập qua Settings page
# (lưu trong localStorage, client-side)
# TWELVE_DATA_API_KEY=

# Email nhận thông báo → nhập qua Settings page
# EMAIL_TO=
