{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "custom": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Custom_1 API",
      "options": {
        "baseURL": "{env:CUSTOM_BASE_URL}",
        "apiKey": "{env:CUSTOM_API_KEY}"
      },
      "models": {
        "glm-5.2": {
          "name": "GLM 5.2"
        }
      }
    }
  },
  "model": "custom/glm-5.2",
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "skill": "allow",
    "external_directory": "allow"
  },
  "instructions": [
    "AGENTS.md",
    "docs/01_PRD.md",
    "docs/02_ARCHITECTURE.md",
    "docs/04_INDICATORS.md",
    "docs/05_SIGNAL_ENGINE.md",
    "docs/06_UI_GUIDE.md"
  ]
}
